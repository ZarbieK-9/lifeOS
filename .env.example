# LifeOS root / shared env (optional)
# Copy to .env and fill: cp .env.example .env

# ── Ngrok (for public backend URL when developing or demoing) ──
# Get token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your-ngrok-token

# Optional: reserved domain (ngrok paid plan). Then run: ./scripts/ngrok-tunnel.sh
# NGROK_DOMAIN=lifeos.ngrok-free.app

# ── Other (e.g. Gemini for backend AI) ──
# gemini_key=...
