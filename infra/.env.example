# LifeOS Infrastructure Configuration
# Copy to .env and fill in values: cp .env.example .env

# ── PostgreSQL ──
POSTGRES_PASSWORD=lifeos_dev

# ── JWT (backend auth) ──
JWT_SECRET=change-me-to-a-random-secret-in-production

# ── Google OAuth (for /oauth/exchange: token exchange with client_secret so the app can sign in with Web client) ──
# Use the same Web application client as in the app (EXPO_PUBLIC_GOOGLE_CLIENT_ID). Set the client secret here.
# GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-web-client-secret
