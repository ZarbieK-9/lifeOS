# LifeOS Frontend — auto-generated
# Expo reads EXPO_PUBLIC_* at build time

# ── Backend (ngrok tunnel when running npm run ngrok) ──
EXPO_PUBLIC_BACKEND_URL=https://showmanly-proevolutionary-kasie.ngrok-free.dev

# ── Google OAuth (Web client). Put only Client ID here. Put the client SECRET in infra/.env as GOOGLE_CLIENT_SECRET. ──
EXPO_PUBLIC_GOOGLE_CLIENT_ID=763277137221-708bdpptadj68ndmkou18d5nil8hq8ea.apps.googleusercontent.com
# Leave false or remove: backend does token exchange with the secret (in infra/.env)
EXPO_PUBLIC_GOOGLE_USE_DESKTOP_CLIENT=false

# ── MQTT credentials (must match mosquitto config in infra/) ──
EXPO_PUBLIC_MQTT_USERNAME=lifeos_user1
EXPO_PUBLIC_MQTT_PASSWORD=lifeos_user1_pass
